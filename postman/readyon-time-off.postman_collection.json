        {
          "name": "POST /time-off-requests/:id/approve - Replay",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              },
              {
                "key": "x-request-id",
                "value": "{{requestId}}",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/time-off-requests/{{timeOffRequestId}}/approve",
              "host": ["{{baseUrl}}"],
              "path": ["time-off-requests", "{{timeOffRequestId}}", "approve"]
            },
            "description": "Run this after a successful approval to show replay-safe approve behavior. The second approval should return the same approved body without a second HCM deduction."
          },
          "response": []
        },
