            ],
            "url": {
              "raw": "{{baseUrl}}/time-off-requests/{{rejectTimeOffRequestId}}/reject",
              "host": ["{{baseUrl}}"],
              "path": [
                "time-off-requests",
                "{{rejectTimeOffRequestId}}",
                "reject"
              ]
            },
            "description": "Rejects the separate pending request created above. Reject does not call HCM when the request is still pending."
          },
          "response": []
        }
      ]
