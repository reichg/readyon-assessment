          "name": "POST /time-off-requests - Create For Rejection",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Create for rejection returns 201 or 200', function () {",
                  "  pm.expect([200, 201]).to.include(pm.response.code);",
                  "});",
                  "pm.test('Save rejectTimeOffRequestId from the response body', function () {",
                  "  const responseBodyJson = pm.response.json();",
                  "  pm.expect(responseBodyJson.id).to.be.a('string').and.not.empty;",
                  "  pm.collectionVariables.set('rejectTimeOffRequestId', responseBodyJson.id);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              },
              {
                "key": "x-request-id",
                "value": "{{requestId}}",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"employeeId\": \"{{employeeId}}\",\n  \"locationId\": \"{{locationId}}\",\n  \"requestedDays\": {{requestedDays}},\n  \"idempotencyKey\": \"{{rejectIdempotencyKey}}\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{baseUrl}}/time-off-requests",
              "host": ["{{baseUrl}}"],
              "path": ["time-off-requests"]
            },
            "description": "Creates a separate pending request so the reject flow does not reuse the request from the approve flow."
          },
          "response": []
        },
        {
          "name": "POST /time-off-requests/:id/reject",
          "request": {
            "method": "POST",
            "header": [
