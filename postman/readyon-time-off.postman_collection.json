            ],
            "url": {
              "raw": "{{baseUrl}}/balances/{{employeeId}}/{{locationId}}/refresh",
              "host": ["{{baseUrl}}"],
              "path": [
                "balances",
                "{{employeeId}}",
                "{{locationId}}",
                "refresh"
              ]
