  "item": [
    {
      "name": "Health",
      "item": [
        {
          "name": "GET /health",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status code is 200', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "pm.test('Health body is ok', function () {",
                  "  const responseBodyJson = pm.response.json();",
                  "  pm.expect(responseBodyJson).to.deep.equal({ status: 'ok' });",
                  "});",
                  "pm.test('Valid x-request-id is echoed back', function () {",
                  "  pm.expect(pm.response.headers.get('x-request-id')).to.equal(pm.collectionVariables.get('requestId'));",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "x-request-id",
                "value": "{{requestId}}",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/health",
              "host": ["{{baseUrl}}"],
              "path": ["health"]
            },
            "description": "Smoke check for the running service. This route also proves the app echoes a valid x-request-id header."
          },
          "response": []
        }
      ]
    },
    {
      "name": "Balances",
      "item": [
        {
          "name": "GET /balances/:employeeId/:locationId",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "x-request-id",
                "value": "{{requestId}}",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/balances/{{employeeId}}/{{locationId}}",
              "host": ["{{baseUrl}}"],
              "path": ["balances", "{{employeeId}}", "{{locationId}}"]
            },
            "description": "Returns the latest known local balance projection. This can legitimately return BALANCE_NOT_FOUND until refresh, reconciliation, or approval side effects have created a projection."
          },
          "response": []
        },
        {
          "name": "POST /balances/:employeeId/:locationId/refresh",
          "request": {
            "method": "POST",
            "header": [
